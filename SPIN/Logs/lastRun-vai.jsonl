+    step = timedelta(days=step_days)
+    t = start_dt
+    prev = phase_delta(natal_dt, t, angle)
+    brackets: list[tuple[datetime, datetime]] = []
+    while t < end_dt:
+        nxt = min(t + step, end_dt)
+        cur = phase_delta(natal_dt, nxt, angle)
+        if prev == 0 or prev * cur <= 0:
+            brackets.append((t, nxt))
+        t = nxt
+        prev = cur
+    return brackets
