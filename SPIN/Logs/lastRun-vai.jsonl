+def format_counter_rows(counter_pairs: list[tuple], label: str, mapper=None) -> list[dict]:
+    rows = []
+    for key, count in counter_pairs:
+        mapped = mapper(key) if mapper else key
+        rows.append({label: key, "count": count, "label_tr": mapped})
+    return rows
