+    candidates: list[datetime] = []
+    for idx in range(1, len(samples) - 1):
+        prev_sep = samples[idx - 1][1]
+        cur_dt, cur_sep = samples[idx]
+        next_sep = samples[idx + 1][1]
+        if cur_sep < 5.0 and cur_sep <= prev_sep and cur_sep <= next_sep:
