+def to_jd(dt_utc: datetime) -> float:
+    import swisseph as swe
+
+    return swe.julday(
+        dt_utc.year,
+        dt_utc.month,
+        dt_utc.day,
+        dt_utc.hour + dt_utc.minute / 60 + dt_utc.second / 3600 + dt_utc.microsecond / 3_600_000_000,
+    )
