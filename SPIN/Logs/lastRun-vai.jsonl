+    roots = [bisect_root(natal_dt, a, b, angle) for a, b in brackets]
+    deduped: list[datetime] = []
+    for root in sorted(roots):
+        if not deduped or abs((root - deduped[-1]).total_seconds()) > 3600:
+            deduped.append(root)
+    return deduped
