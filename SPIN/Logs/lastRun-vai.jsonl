+            "progressed_sun_lon": round(event.progressed_sun_lon, 6),
+            "progressed_moon_lon": round(event.progressed_moon_lon, 6),
+            "moon_minus_sun_deg": round(event.separation, 6),
+            "exact_delta_deg": round(event.exact_delta, 9),
+        }
+    ]
