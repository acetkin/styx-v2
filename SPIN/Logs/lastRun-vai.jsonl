code == 422\\n    _assert_meta_versions(resp)\\n    errors = _error_items(resp)\\n    item = _find_error_by_path(errors, \\\"/metadata/chart_type\\\")\\n    assert item[\\\"code\\\"] == \\\"UNSUPPORTED_VALUE\\\"\\n    assert \\\"message\\\" in item\\n\\n\\ndef test_transit_basic(monkeypatch: object) -> None:\\n    client = _client(monkeypatch)\\n    resp = client.post(\\n        \\\"/v1/transit\\\",\\n        json={\\n            \\\"metadata\\\": {\\\"transit_type\\\": \\\"transit\\\"},\\n            \\\"frame_a\\\": {\\n                \\\"metadata\\\": {\\n                    \\\"chart_type\\\": \\\"natal\\\",\\n\",\"exit_code\":0,\"status\":\"completed\"}}\n2f0548e1840901f6c6e3ca32cc45645c489bdc5a:SPIN/Logs/lastRun-vai.jsonl:64:{\"type\":\"item.completed\",\"item\":{\"id\":\"item_32\",\"type\":\"command_execution\",\"command\":\"/bin/bash -lc \\\"sed -n '1,260p' SPIN/docs/contract.json\\\"\",\"aggregated_output\":\"{\\n  \\\"styx_version\\\": \\\"3.0.0\\\",\\n  \\\"glossary\\\": {\\n    \\\"formats\\\": {\\n      \\\"ISO8601\\\": \\\"RFC3339-compatible timestamp.\\\",\\n      \\\"YYYY-MM-DD\\\": \\\"Calendar date string.\\\",\\n      \\\"HH:MM\\\": \\\"24h local time string.\\\"\\n    },\\n    \\\"enums\\\": {\\n      \\\"status\\\": [\\\"contract\\\", \\\"ok\\\", \\\"error\\\"],\\n      \\\"zodiac\\\": [\\\"tropical\\\", \\\"sidereal\\\"],\\n      \\\"verbosity\\\": [\\\"minimal\\\", \\\"normal\\\", \\\"verbose\\\"],\\n      \\\"confidence\\\": [\\\"low\\\", \\\"medium\\\", \\\"high\\\"],\\n      \\\"astrocartographic_scope\\\": [\\\"world\\\", \\\"region\\\"],\\n      \\\"timeline_step\\\": [\\\"hour\\\", \\\"day\\\", \\\"week\\\", \\\"month\\\"]\\n    },\\n    \\\"terms\\\": {\\n      \\\"overlay\\\": \\\"A secondary frame applied on top of a base chart (used in Transit/Timeline requests).\\\",\\n      \\\"astrological_objects\\\": \\\"Optional allowlist of named output blocks to include in responses.\\\",\\n      \\\"node_axis_seasons\\\": \\\"node_axis_time