e\\\": \\\"transit\\\"},\\n            \\\"frame_a\\\": {\\n                \\\"metadata\\\": {\\n                    \\\"chart_type\\\": \\\"natal\\\",\\n\",\"exit_code\":0,\"status\":\"completed\"}}\n2a21956085bb5b64535e42fab9ddc9a77aa9fc3d:SPIN/Logs/lastRun-vai.jsonl:64:{\"type\":\"item.completed\",\"item\":{\"id\":\"item_32\",\"type\":\"command_execution\",\"command\":\"/bin/bash -lc \\\"sed -n '1,260p' SPIN/docs/contract.json\\\"\",\"aggregated_output\":\"{\\n  \\\"styx_version\\\": \\\"3.0.0\\\",\\n  \\\"glossary\\\": {\\n    \\\"formats\\\": {\\n      \\\"ISO8601\\\": \\\"RFC3339-compatible timestamp.\\\",\\n      \\\"YYYY-MM-DD\\\": \\\"Calendar date string.\\\",\\n      \\\"HH:MM\\\": \\\"24h local time string.\\\"\\n    },\\n    \\\"enums\\\": {\\n      \\\"status\\\": [\\\"contract\\\", \\\"ok\\\", \\\"error\\\"],\\n      \\\"zodiac\\\": [\\\"tropical\\\", \\\"sidereal\\\"],\\n      \\\"verbosity\\\": [\\\"minimal\\\", \\\"normal\\\", \\\"verbose\\\"],\\n      \\\"confidence\\\": [\\\"low\\\", \\\"medium\\\", \\\"high\\\"],\\n      \\\"astrocartographic_scope\\\": [\\\"world\\\", \\\"region\\\"],\\n      \\\"timeline_step\\\": [\\\"hour\\\", \\\"day\\\", \\\"week\\\", \\\"month\\\"]\\n    },\\n    \\\"terms\\\": {\\n      \\\"overlay\\\": \\\"A secondary frame applied on top of a base chart (used in Transit/Timeline requests).\\\",\\n      \\\"astrological_objects\\\": \\\"Optional allowlist of named output blocks to include in responses.\\\",\\n      \\\"node_axis_seasons\\\": \\\"node_axis_timeline: 5 nodal cycles (~18.6y each) treated as seasons (~93y total).\\\",\\n      \\\"node_axis_chapters\\\": \\\"node_axis_timeline: each season is divided into 12 chapters using 30° slices away from the natal nodal axis (30,60,...,360). Nodal axis is retro, so slices progress backwards in time.\\\"\\n    }\\n  },\\n\\n  \\\"universal_request_form\\\": {\\n    \\\"metadata\\\": {\\n      \\\"styx_version\\\": \\\"string\\\",\\n      \\\"request_id\\\": \\\"string\