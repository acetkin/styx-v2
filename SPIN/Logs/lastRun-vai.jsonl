+    pdt = progressed_datetime(natal_dt, target_dt)
+    jd = to_jd(pdt)
+    sun = _calc_body(jd, swe.SUN, "sun")
+    moon = _calc_body(jd, swe.MOON, "moon")
+    separation = _normalize_deg(moon["lon"] - sun["lon"])
+    return {
+        "progressed_utc": pdt,
+        "sun_lon": sun["lon"],
+        "moon_lon": moon["lon"],
+        "separation": separation,
+    }
