\n          \\\"player.birth.time\\\",\\n          \\\"player.birth.country_code\\\",\\n          \\\"request.parameters.overlay.at\\\"\\n        ],\\n        \\\"template\\\": { \\\"request\\\": { \\\"parameters\\\": { \\\"overlay\\\": { \\\"at\\\": \\\"ISO8601?\\\" } } } }\\n      },\\n      \\\"ok_response\\\": {\\n        \\\"summary_template\\\": { \\\"intent\\\": \\\"transit_to_natal\\\", \\\"at\\\": \\\"ISO8601\\\" },\\n        \\\"data_template\\\": {\\n          \\\"transit_to_natal\\\": {\\n            \\\"at\\\": \\\"ISO8601\\\",\\n            \\\"base\\\": { \\\"natal\\\": {} },\\n            \\\"overlay\\\": { \\\"transit\\\": {} },\\n            \\\"aspects\\\": []\\n          }\\n        }\\n      }\\n    },\\n\\n    \\\"progressed_to_natal\\\": {\\n      \\\"group\\\": \\\"TRANSIT\\\",\\n      \\\"description\\\": \\\"Progressed overlay applied to natal at a single instant.\\\",\\n      \\\"request\\\": {\\n        \\\"required_paths\\\": [\\\"player.birth.date\\\", \\\"player.birth.place\\\", \\\"request.parameters.overlay.at\\\"],\\n        \\\"optional_paths\\\": [\\\"player.birth.time\\\", \\\"player.birth.country_code\\\"],\\n        \\\"template\\\": { \\\"request\\\": { \\\"parameters\\\": { \\\"overlay\\\": { \\\"at\\\": \\\"ISO8601\\\" } } } }\\n      },\\n      \\\"ok_response\\\": {\\n        \\\"summary_template\\\": { \\\"intent\\\": \\\"progressed_to_natal\\\", \\\"at\\\": \\\"ISO8601\\\" },\\n        \\\"data_template\\\": {\\n          \\\"progressed_to_natal\\\": {\\n            \\\"at\\\": \\\"ISO8601\\\",\\n            \\\"base\\\": { \\\"natal\\\": {} },\\n            \\\"overlay\\\": { \\\"progressed\\\": {} },\\n            \\\"aspects\\\": []\\n          }\\n        }\\n      }\\n    },\\n\\n    \\\"solar_arc_to_natal\\\": {\\n      \\\"group\\\": \\\"TRANSIT\\\",\\n      \\\"description\\\": \\\"Solar Arc overlay applied to natal at a single instant.\\\",\\n      \\\"request\\\": {\\n        \\\"required_paths\\\": [\\\"player