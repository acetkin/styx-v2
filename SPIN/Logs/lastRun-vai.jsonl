+def markdown_table(rows: list[dict], columns: list[str]) -> str:
+    if not rows:
+        return "_Boş_"
+    header = "| " + " | ".join(columns) + " |"
+    sep = "| " + " | ".join("---" for _ in columns) + " |"
+    body = []
+    for row in rows:
+        body.append("| " + " | ".join(str(row.get(col, "")) for col in columns) + " |")
+    return "\n".join([header, sep, *body])
+
