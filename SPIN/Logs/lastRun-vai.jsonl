+def build_validation_table(event: Event) -> list[dict]:
+    return [
+        {
+            "target_angle_deg": event.target_angle,
+            "event_utc": event.event_utc.isoformat().replace("+00:00", "Z"),
+            "event_local": event.event_local.isoformat(),
